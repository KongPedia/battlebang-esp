# Copy to src/turret_fleet/.env.turret_fleet (gitignored) or export these variables per command.
# Do not commit real Wi-Fi/MQTT secrets.

TURRET_FLEET_WIFI_SSID=YOUR_WIFI_SSID
TURRET_FLEET_WIFI_PASSWORD=YOUR_WIFI_PASSWORD
TURRET_FLEET_MQTT_HOST=10.2.80.52
TURRET_FLEET_MQTT_PORT=1883
TURRET_FLEET_MQTT_ROOT=battlebang

# First install defaults. Firmware still forces boot Wi-Fi/MQTT for configured
# fleet turrets; keep the persisted config aligned with that behavior.
TURRET_FLEET_NETWORK_AUTO_START=true
TURRET_FLEET_YAW_STOP_US=1500
TURRET_FLEET_PITCH_STOP_US=1500
TURRET_FLEET_HOME_YAW_DEG=0
TURRET_FLEET_HOME_PITCH_DEG=0
TURRET_FLEET_YAW_MIN_DEG=-75
TURRET_FLEET_YAW_MAX_DEG=75
TURRET_FLEET_PITCH_MIN_DEG=-75
TURRET_FLEET_PITCH_MAX_DEG=75
TURRET_FLEET_SERVO_MAX_DELTA_US=220
TURRET_FLEET_YAW_MIN_DRIVE_US=150
TURRET_FLEET_PITCH_MIN_DRIVE_US=80
TURRET_FLEET_SERVO_ATTACH_SETTLE_MS=350
TURRET_FLEET_AXIS_SWITCH_COOLDOWN_MS=800
TURRET_FLEET_AXIS_DIVERGENCE_GUARD_MS=3000
TURRET_FLEET_AXIS_DIVERGENCE_MARGIN_DEG=20.0

# Optional per-install overrides.
# TURRET_FLEET_CONFIG_VERSION=2001
# TURRET_FLEET_DEAD_PITCH_DEG=20
# TURRET_FLEET_FIRE_DEFAULT_HOLD_MS=500
# TURRET_FLEET_FIRE_ESC_RUN_US=1700
