#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
FLASH_SCRIPT="$ROOT_DIR/scripts/turret_flash.py"
FLEET_PROVISION_SCRIPT="$ROOT_DIR/scripts/turret_fleet/provision.py"
FLEET_MQTT_SCRIPT="$ROOT_DIR/scripts/turret_fleet/mqtt_command.py"
FLEET_OTA_PUBLISH_SCRIPT="$ROOT_DIR/scripts/turret_fleet/publish_mqtt_manifest.py"
PIO_BIN="$ROOT_DIR/.venv-pio/bin/pio"
PYTHON_BIN="$ROOT_DIR/.venv-pio/bin/python"
TURRETS_JSON="$ROOT_DIR/src/turret/turrets.json"
LOCAL_SECRETS="$ROOT_DIR/src/turret/local_secrets.h"
UPLOAD_TARGETS="$ROOT_DIR/src/turret/upload_targets.toml"
FLEET_ENV_FILE="${TURRET_FLEET_ENV_FILE:-$ROOT_DIR/src/turret_fleet/.env.turret_fleet}"
declare -a SECRET_ARGS=()

if [[ ! -x "$PIO_BIN" ]]; then
  PIO_BIN="pio"
fi
if [[ ! -x "$PYTHON_BIN" ]]; then
  PYTHON_BIN="python3"
fi

usage() {
  cat <<'USAGE'
BattleBang turret helper

Usage:
  ./bin/turret ports
  ./bin/turret show <turret-number|turret_id>
  ./bin/turret build <turret-number|turret_id>
  ./bin/turret upload <turret-number|turret_id> [port]
  ./bin/turret build-all
  ./bin/turret upload-all
  ./bin/turret fleet-config <turret-number|turret_id>
  ./bin/turret fleet-provision <turret-number|turret_id> [port]
  ./bin/turret fleet-upload <turret-number|turret_id> [port]
  ./bin/turret fleet-mqtt <turret-number|turret_id> <idle|dead|hold|recover|target|aim|fire|config|update> [options]
  ./bin/turret fleet-ota-publish <manifest.json> [topic]
  ./bin/turret monitor [port]
  ./bin/turret config

Examples:
  ./bin/turret ports
  ./bin/turret show 5
  ./bin/turret build 5
  ./bin/turret upload 5 /dev/cu.usbserial-1120
  ./bin/turret upload 5
  ./bin/turret monitor /dev/cu.usbserial-1120
  ./bin/turret build-all
  ./bin/turret upload-all
  ./bin/turret fleet-upload 2
  ./bin/turret fleet-provision turret_2 /dev/cu.usbserial-120
  ./bin/turret fleet-mqtt turret_2 target 0 0 1
  ./bin/turret fleet-mqtt turret_2 aim 0 10
  ./bin/turret fleet-mqtt turret_2 recover
  ./bin/turret fleet-mqtt turret_2 fire --duration-ms 500
  ./bin/turret fleet-mqtt turret_2 update --desired-build 7
  ./bin/turret fleet-mqtt turret_2 config --ota-auto-check-enabled true --ota-desired-build 2
  ./bin/turret fleet-ota-publish dist/manifest.json battlebang/turrets/all/ota

Secrets:
  - Default: src/turret/local_secrets.h
  - Optional one-shot override:
      TURRET_WIFI_SSID=YOUR_WIFI_SSID \
      TURRET_WIFI_PASSWORD=YOUR_WIFI_PASSWORD \
      TURRET_MQTT_HOST=COMMAND_CENTER_IP \
      ./bin/turret upload 5

Fleet first provisioning:
  - Copy src/turret_fleet/.env.turret_fleet.example -> src/turret_fleet/.env.turret_fleet and fill Wi-Fi/MQTT.
  - `fleet-upload 2` uploads one generic esp32dev_turret_fleet image and then
    injects turret_2 runtime config over USB serial into ESP32 NVS.
  - Env file can be overridden with TURRET_FLEET_ENV_FILE=/path/to/.env.
  - `fleet-mqtt` reads the same module-local env file for broker host/port/root. Use
    --host "$MQTT_BROKER_HOST" when the env file is absent; this host is the MQTT broker,
    not the ESP device IP. Example: MQTT_BROKER_HOST=COMMAND_CENTER_IP_OR_DNS.
  - `fleet-mqtt ... update --desired-build N` approves polling against the GitHub latest manifest.
  - `fleet-ota-publish` publishes a full release manifest to MQTT for direct OTA jobs.
USAGE
}

normalize_turret() {
  local raw="${1:-}"
  case "$raw" in
    [1-9])
      echo "turret_${raw}"
      ;;
    turret_*)
      echo "$raw"
      ;;
    *)
      echo "[bin/turret] invalid turret id: ${raw:-<empty>} (use 5 or turret_5)" >&2
      exit 2
      ;;
  esac
}

build_secret_args() {
  SECRET_ARGS=()
  if [[ -n "${TURRET_WIFI_SSID:-}" ]]; then
    SECRET_ARGS+=(--wifi-ssid "$TURRET_WIFI_SSID")
  fi
  if [[ -n "${TURRET_WIFI_PASSWORD:-}" ]]; then
    SECRET_ARGS+=(--wifi-password "$TURRET_WIFI_PASSWORD")
  fi
  if [[ -n "${TURRET_MQTT_HOST:-}" ]]; then
    SECRET_ARGS+=(--mqtt-host "$TURRET_MQTT_HOST")
  fi
  if [[ -n "${TURRET_MQTT_PORT:-}" ]]; then
    SECRET_ARGS+=(--mqtt-port "$TURRET_MQTT_PORT")
  fi
  if [[ -n "${TURRET_MQTT_USERNAME:-}" ]]; then
    SECRET_ARGS+=(--mqtt-username "$TURRET_MQTT_USERNAME")
  fi
  if [[ -n "${TURRET_MQTT_PASSWORD:-}" ]]; then
    SECRET_ARGS+=(--mqtt-password "$TURRET_MQTT_PASSWORD")
  fi
}

filtered_ports() {
  "$PIO_BIN" device list --json-output | python3 -c '
import json
import sys

try:
    data = json.load(sys.stdin)
except Exception:
    data = []

ignore_exact = {
    "/dev/cu.debug-console",
    "/dev/cu.Bluetooth-Incoming-Port",
}
ignore_contains = ("Bluetooth", "debug-console")

for item in data:
    port = str(item.get("port", "")).strip()
    if not port:
        continue
    if port in ignore_exact:
        continue
    if any(token in port for token in ignore_contains):
        continue
    print(port)
'
}

auto_detect_port() {
  local ports=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && ports+=("$line")
  done < <(filtered_ports)
  if [[ ${#ports[@]} -eq 1 ]]; then
    printf '%s\n' "${ports[0]}"
    return 0
  fi

  if [[ ${#ports[@]} -eq 0 ]]; then
    echo "[bin/turret] no USB serial device detected. Run ./bin/turret ports" >&2
    return 2
  fi

  echo "[bin/turret] multiple USB serial devices detected. Specify the port explicitly." >&2
  printf '  - %s\n' "${ports[@]}" >&2
  return 3
}

show_turret() {
  local turret_id="$1"
  python3 - "$TURRETS_JSON" "$LOCAL_SECRETS" "$turret_id" <<'PY'
import json
import sys
from pathlib import Path

config_path = Path(sys.argv[1])
secrets_path = Path(sys.argv[2])
turret_id = sys.argv[3]
data = json.loads(config_path.read_text(encoding='utf-8'))
entry = data.get('turrets', {}).get(turret_id)
if entry is None:
    print(f"unknown turret: {turret_id}", file=sys.stderr)
    raise SystemExit(2)

def deep_merge(base, override):
    merged = dict(base or {})
    for key, value in (override or {}).items():
        if isinstance(value, dict) and isinstance(merged.get(key), dict):
            merged[key] = deep_merge(merged[key], value)
        else:
            merged[key] = value
    return merged

print(f"turret: {turret_id}")
print(f"configured: {entry.get('configured', False)}")
for key in ('x_cm', 'y_cm', 'z_cm', 'default_target_z_cm', 'pitch_offset_deg', 'yaw_offset_deg'):
    if key in entry:
        print(f"{key}: {entry[key]}")
motion = deep_merge(data.get('motion_defaults', {}), entry.get('motion', {}))
for axis in ('yaw', 'pitch'):
    axis_motion = motion.get(axis, {}) if isinstance(motion, dict) else {}
    if not isinstance(axis_motion, dict) or not axis_motion:
        continue
    keys = ('cmd_min_deg', 'cmd_max_deg', 'idle_min_deg', 'idle_max_deg', 'idle_speed_deg_per_sec', 'dead_deg', 'invert_motor')
    summary = ', '.join(f"{key}={axis_motion[key]}" for key in keys if key in axis_motion)
    print(f"{axis}_motion: {summary}")
print(f"local_secrets: {'present' if secrets_path.exists() else 'missing'}")
PY
}

require_upload_targets() {
  if [[ ! -f "$UPLOAD_TARGETS" ]]; then
    echo "[bin/turret] missing $UPLOAD_TARGETS" >&2
    echo "[bin/turret] copy src/turret/upload_targets.example.toml -> src/turret/upload_targets.toml and fill the USB ports." >&2
    exit 2
  fi
}

run_flash_script() {
  local cmd=(python3 "$FLASH_SCRIPT" flash)
  cmd+=("$@")
  if [[ ${#SECRET_ARGS[@]} -gt 0 ]]; then
    cmd+=("${SECRET_ARGS[@]}")
  fi
  "${cmd[@]}"
}

cmd="${1:-help}"
case "$cmd" in
  help|-h|--help)
    usage
    ;;
  ports)
    ports=()
    while IFS= read -r line; do
      [[ -n "$line" ]] && ports+=("$line")
    done < <(filtered_ports)
    if [[ ${#ports[@]} -eq 0 ]]; then
      echo "[bin/turret] no USB serial device detected." >&2
      exit 2
    fi
    printf '%s\n' "${ports[@]}"
    ;;
  config)
    python3 "$FLASH_SCRIPT" show-config
    ;;
  show)
    turret_id="$(normalize_turret "${2:-}")"
    show_turret "$turret_id"
    ;;
  build)
    turret_id="$(normalize_turret "${2:-}")"
    shift 2 || true
    build_secret_args
    run_flash_script --build-only --skip-port-check --target "$turret_id" "$@"
    ;;
  upload|flash)
    turret_id="$(normalize_turret "${2:-}")"
    shift 2 || true
    port="${1:-}"
    if [[ -z "$port" || "$port" == --* ]]; then
      port="$(auto_detect_port)"
    else
      shift || true
    fi
    build_secret_args
    run_flash_script --target "$turret_id=$port" "$@"
    ;;
  build-all)
    shift || true
    build_secret_args
    require_upload_targets
    run_flash_script --build-only --skip-port-check --map-file "$UPLOAD_TARGETS" "$@"
    ;;
  upload-all|flash-all)
    shift || true
    build_secret_args
    require_upload_targets
    run_flash_script --map-file "$UPLOAD_TARGETS" "$@"
    ;;
  fleet-config)
    turret_id="$(normalize_turret "${2:-}")"
    shift 2 || true
    exec "$PYTHON_BIN" "$FLEET_PROVISION_SCRIPT" build-config "$turret_id" --env-file "$FLEET_ENV_FILE" "$@"
    ;;
  fleet-mqtt)
    if [[ "${2:-}" == "help" || "${2:-}" == "-h" || "${2:-}" == "--help" || -z "${2:-}" ]]; then
      exec "$PYTHON_BIN" "$FLEET_MQTT_SCRIPT" --help
    fi
    turret_id="$(normalize_turret "${2:-}")"
    shift 2 || true
    exec "$PYTHON_BIN" "$FLEET_MQTT_SCRIPT" --env-file "$FLEET_ENV_FILE" "$turret_id" "$@"
    ;;
  fleet-ota-publish)
    shift || true
    manifest="${1:-}"
    if [[ -z "$manifest" ]]; then
      echo "[bin/turret] fleet-ota-publish requires a manifest path" >&2
      usage >&2
      exit 2
    fi
    shift || true
    topic="${1:-battlebang/turrets/all/ota}"
    "$PYTHON_BIN" - "$FLEET_ENV_FILE" "$manifest" "$topic" "$FLEET_OTA_PUBLISH_SCRIPT" <<'PY'
import os
import sys
from pathlib import Path

env_file = Path(sys.argv[1])
manifest = sys.argv[2]
topic = sys.argv[3]
script = sys.argv[4]
values = {}
if env_file.exists():
    for raw in env_file.read_text(encoding="utf-8").splitlines():
        line = raw.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, value = line.split("=", 1)
        value = value.strip().strip("'\"")
        values[key.strip()] = value
host = os.environ.get("TURRET_FLEET_MQTT_HOST") or values.get("TURRET_FLEET_MQTT_HOST") or os.environ.get("TURRET_MQTT_HOST") or values.get("TURRET_MQTT_HOST")
port = os.environ.get("TURRET_FLEET_MQTT_PORT") or values.get("TURRET_FLEET_MQTT_PORT") or os.environ.get("TURRET_MQTT_PORT") or values.get("TURRET_MQTT_PORT") or "1883"
username = os.environ.get("TURRET_FLEET_MQTT_USERNAME") or values.get("TURRET_FLEET_MQTT_USERNAME") or ""
password = os.environ.get("TURRET_FLEET_MQTT_PASSWORD") or values.get("TURRET_FLEET_MQTT_PASSWORD") or ""
if not host:
    raise SystemExit("missing TURRET_FLEET_MQTT_HOST or TURRET_MQTT_HOST")
cmd = [sys.executable, script, "--host", host, "--port", str(port), "--topic", topic, "--manifest", manifest]
if username:
    cmd += ["--username", username]
if password:
    cmd += ["--password", password]
os.execv(sys.executable, cmd)
PY
    ;;
  fleet-provision)
    turret_id="$(normalize_turret "${2:-}")"
    shift 2 || true
    port="${1:-}"
    if [[ -z "$port" || "$port" == --* ]]; then
      port="$(auto_detect_port)"
    else
      shift || true
    fi
    exec "$PYTHON_BIN" "$FLEET_PROVISION_SCRIPT" provision "$turret_id" --env-file "$FLEET_ENV_FILE" --port "$port" "$@"
    ;;
  fleet-upload|fleet-flash)
    turret_id="$(normalize_turret "${2:-}")"
    shift 2 || true
    port="${1:-}"
    if [[ -z "$port" || "$port" == --* ]]; then
      port="$(auto_detect_port)"
    else
      shift || true
    fi
    "$PIO_BIN" run -e esp32dev_turret_fleet -t upload --upload-port "$port"
    exec "$PYTHON_BIN" "$FLEET_PROVISION_SCRIPT" provision "$turret_id" --env-file "$FLEET_ENV_FILE" --port "$port" "$@"
    ;;
  monitor)
    shift || true
    port="${1:-}"
    if [[ -z "$port" || "$port" == --* ]]; then
      port="$(auto_detect_port)"
    else
      shift || true
    fi
    exec "$PIO_BIN" device monitor -b 115200 -p "$port" "$@"
    ;;
  *)
    echo "[bin/turret] unknown command: $cmd" >&2
    usage >&2
    exit 2
    ;;
esac
